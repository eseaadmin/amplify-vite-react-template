{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node", "aws-lambda"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["ES2022"]
  },
  "include": ["*.ts"],
  "exclude": ["node_modules"]
}
